# Compiled binary copied to project root by mise build tasks
# Older builds dropped this as plain `rio`; current tasks append the
# target OS (and optionally the display-server feature).
/rio
/rio-linux
/rio-linux-wayland
/rio-linux-x11
/rio-macos
/rio-windows.exe

# These are backup files generated by rustfmt
**/*.rs.bk

# required by nix
.direnv/
result/
/result

target/
.DS_Store
rls/
.vs
.vscode
.swp
release
.jekyll-cache
.jekyll-metadata
NOTES
*.log

# for nix users
.direnv/

# compiled terminfo files
misc/72/

# goreleaser
dist/

# Compiled SPIR-V — generated at build time by sugarloaf/build.rs into
# OUT_DIR. The GLSL sources are checked in; the bytecode isn't.
sugarloaf/src/**/*.spv
